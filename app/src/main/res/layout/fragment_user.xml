<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Screen Title Header -->
    <TextView
        android:id="@+id/text_user_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/soundtrack_you"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <!-- Static Sub-navigation Bar to switch layout visibility -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#EEEEEE">
        <Button
            android:id="@+id/tab_toggle_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="@string/profile" />
        <Button
            android:id="@+id/tab_toggle_lists"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="@string/lists" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- SUB-LAYOUT A: Profile View Contents -->
        <ScrollView
            android:id="@+id/scroll_profile_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/sym_def_app_icon"
                    android:contentDescription="@string/desc_user_avatar"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/text_username_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_username"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/top_5_albums"
                    android:textStyle="bold" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_top_five"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/last_listens"
                    android:textStyle="bold" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_last_listens"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/fav_artists"
                    android:textStyle="bold" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_fav_artists"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </ScrollView>

        <!-- SUB-LAYOUT B: Catalog Lists View (Initially Hidden) -->
        <LinearLayout
            android:id="@+id/layout_lists_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <!-- Dynamic Sorting Categories Row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/chip_all" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/list_filter_all" style="@style/Widget.MaterialComponents.Button.TextButton"/>
                    <Button android:id="@+id/chip_logged" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/list_filter_logged" style="@style/Widget.MaterialComponents.Button.TextButton"/>
                    <Button android:id="@+id/chip_plan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/list_filter_plan" style="@style/Widget.MaterialComponents.Button.TextButton"/>
                    <Button android:id="@+id/chip_custom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/list_filter_my_lists" style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </LinearLayout>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_vertical_catalog_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

    </FrameLayout>
</LinearLayout>